# Copy to server/.env and client/.env (see README)

# --- Server (server/.env) ---
NODE_ENV=development
PORT=4000

# Local Vite dev server: http://localhost:5173
# Docker client container (nginx): http://localhost:8080
CLIENT_URL=http://localhost:5173

# Local Node + local MongoDB:
# MONGODB_URI=mongodb://localhost:27017/smartleads
# Docker Compose networking (service-name DNS):
MONGODB_URI=mongodb://mongo:27017/smartleads

JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# Admin seed (server: npm run seed:admin)
ADMIN_NAME=Admin User
ADMIN_EMAIL=admin@smartleads.local
ADMIN_PASSWORD=change_me_admin_password

# --- Client (client/.env) ---
# Browser-facing API URL; browser localhost != container localhost
VITE_API_URL=http://localhost:4000/api
