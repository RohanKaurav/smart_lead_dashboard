NODE_ENV=development
PORT=4000

# Browser origin allowed by CORS. Use http://localhost:8080 for docker-compose.
CLIENT_URL=http://localhost:5173

# For local Node + local MongoDB:
# MONGODB_URI=mongodb://localhost:27017/smartleads
# For docker-compose networking (inside containers):
MONGODB_URI=mongodb://mongo:27017/smartleads

JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# Admin seed (npm run seed:admin)
ADMIN_NAME=Admin User
ADMIN_EMAIL=admin@smartleads.local
ADMIN_PASSWORD=change_me_admin_password
